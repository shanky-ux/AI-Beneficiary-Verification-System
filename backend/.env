# SS Fraud Prevention System — Backend Environment
# Generated automatically. Safe for local development.
# CHANGE all secrets before any production use.

NODE_ENV=development
PORT=4000

# CORS — allow the frontend origin
FRONTEND_ORIGIN=http://localhost:3000

# JWT secrets — these are safe random dev values
JWT_SECRET=ss-fraud-dev-jwt-secret-localonly-change-in-prod-abc123
JWT_REFRESH_SECRET=ss-fraud-dev-refresh-secret-different-from-jwt-xyz789

# AES-256-GCM field encryption key (64 hex chars = 32 bytes)
# WARNING: If you change this, existing encrypted data (aadhaar, bank) cannot be decrypted.
FIELD_ENCRYPTION_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2

# Fraud engine thresholds (0-100)
FRAUD_AUTO_STOP_THRESHOLD=75
FRAUD_FLAG_THRESHOLD=50

# Logging
LOG_LEVEL=info
